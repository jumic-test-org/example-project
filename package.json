    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jest": "^30",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.1"
  },
